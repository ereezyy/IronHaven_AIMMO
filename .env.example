# IronHaven AIMMO local environment
#
# Supabase — optional. If unset, the app boots in offline mode
# (localStorage persistence, no multiplayer presence).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# xAI Grok — optional. Powers NPC dialogue + street contracts.
# Create a key at https://console.x.ai
# The game stays fully playable without this (scripted dialogue fallback).

VITE_XAI_API_KEY=
# Alias also accepted:
# VITE_GROK_API_KEY=

# Stripe — Iron Haven Pass ($1.99/week).
# Run once:  node scripts/setup-production-env.mjs
# (reads C:\Users\Eddy\Documents\keys.txt, creates product + Payment Link)
#
# Success URL must include ?pass=success (configured on the Payment Link).
VITE_STRIPE_PAYMENT_LINK=
# Aliases:
# VITE_STRIPE_CHECKOUT_URL=
# VITE_STRIPE_PASS_URL=
#
# Publishable key is optional client-side (Payment Link does not require it).
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
#
# Restore API (Supabase Edge Function stripe-pass-status):
VITE_STRIPE_PASS_API=
#
# --- Server only (never VITE_ / never commit) ---
# File: .env.server  (gitignored) written by setup-production-env.mjs
#   STRIPE_SECRET_KEY=
#   STRIPE_WEBHOOK_SECRET=
#
# Deploy edge functions:
#   npx supabase functions deploy stripe-pass-webhook --no-verify-jwt
#   npx supabase functions deploy stripe-pass-status --no-verify-jwt
#   npx supabase secrets set STRIPE_SECRET_KEY=sk_live_... STRIPE_WEBHOOK_SECRET=whsec_...
#
# Stripe Dashboard → Webhooks →
#   https://<project-ref>.supabase.co/functions/v1/stripe-pass-webhook
# Events: checkout.session.completed, customer.subscription.updated,
#         customer.subscription.deleted, invoice.paid, invoice.payment_failed
